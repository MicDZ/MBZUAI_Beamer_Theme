% beamerthemeMBZUAI.sty
% MBZUAI Beamer Theme
% Based on MBZUAI Brand Guidelines (March 2026, V1)
%
% Usage: \usetheme{MBZUAI}
%
% Options:
%   [dark]   - Dark theme (navy background)
%   [light]  - Light theme (white background, default)

\mode<presentation>

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamerthemeMBZUAI}[2026/03/01 MBZUAI Beamer Theme v1.0]

% ── Required packages ──────────────────────────────────────────────────────
\RequirePackage{tikz}
\RequirePackage{graphicx}
\RequirePackage{xcolor}
\RequirePackage{colortbl}
\RequirePackage{pgffor}

% ── Graphics path ──────────────────────────────────────────────────────────
\graphicspath{{assets/}}

% ── Load sub-themes ────────────────────────────────────────────────────────
\usecolortheme{MBZUAI}
\usefonttheme{MBZUAI}
\useinnertheme{MBZUAI}
\useoutertheme{MBZUAI}

% ── Fix vertical centering: symmetric fills ────────────────────────────────
\AtBeginDocument{%
    \define@key{beamerframe}{c}[true]{%
        \beamer@frametopskip=0pt plus 1fill\relax%
        \beamer@framebottomskip=0pt plus 1fill\relax%
        \beamer@frametopskipautobreak=0pt plus 1fill\relax%
        \beamer@framebottomskipautobreak=0pt plus 1fill\relax%
    }%
}

\mode<all>
