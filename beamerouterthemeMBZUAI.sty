% beamerouterthemeMBZUAI.sty
% MBZUAI Outer Theme: Frametitle and Footline
% Based on MBZUAI Brand Guidelines (March 2026, V1)

\mode<presentation>

% ── Remove navigation symbols ──────────────────────────────────────────────
\setbeamertemplate{navigation symbols}{}

% ── Customizable footer commands ──────────────────────────────────────────────
\newcommand{\mbzuai@footleft}{}
\newcommand{\mbzuai@footmid}{}
\newcommand{\mbzuai@footright}{}
\newcommand{\footleft}[1]{\renewcommand{\mbzuai@footleft}{#1}}
\newcommand{\footmid}[1]{\renewcommand{\mbzuai@footmid}{#1}}
\newcommand{\footright}[1]{\renewcommand{\mbzuai@footright}{#1}}

% ── Frametitle with composite banner background ────────────────────────────
\setbeamertemplate{frametitle}{%
    \nointerlineskip
    % Outer box: full banner height, no depth (banner extends to bottom)
    \begin{beamercolorbox}[wd=\paperwidth, ht=2.5em, dp=0.0em, leftskip=1.5em]{frametitle}%
        % Composite banner overlay (zero width, doesn't affect layout)
        \hbox to0pt{%
            \tikz{
                \node[anchor=north west, inner sep=0]
                    at (0, 0)
                    {\includegraphics[width=\paperwidth]{banner-bg.pdf}};
            }%
        \hss}%
        % Title text with bottom spacing via raisebox
        \raisebox{0.6em}{\usebeamerfont{frametitle}\insertframetitle}%
        \hfill
        % Logo on the right
        \raisebox{0.3em}{\includegraphics[height=1.8em]{logo_sand.pdf}}%
        \hspace{1.5em}%
    \end{beamercolorbox}%
    \nointerlineskip
    % Sand separator line (overlay, no extra space)
    \tikz[remember picture, overlay]{\fill[mbzuai-sand] (current page.north west) ++(0,-2.5em) rectangle ++(\paperwidth,-1.5pt);}
}

% ── Footer with banner background and customizable content ────────────────────
\setbeamertemplate{footline}{%
    \leavevmode%
    % Content with correct height for beamer's textheight calculation
    \begin{beamercolorbox}[wd=\paperwidth, ht=3em, dp=0em, leftskip=3em, rightskip=3em,vmode]{footline}%
        % Banner background overlay (positioned at bottom of page)
        \tikz[remember picture, overlay]{%
            \node[anchor=south west, inner sep=0, outer sep=0]
                at (current page.south west)
                {\includegraphics[width=\paperwidth, height=3em]{banner-bg.pdf}};
        }%
        % Vertically center text
        \vbox to 3em{%
            \vfil
            {\footnotesize \textcolor{white}{\mbzuai@footleft}}%
            \hspace{1.2em}%
            {\footnotesize \textcolor{mbzuai-sand}{|}}%
            \hspace{1.2em}%
            {\footnotesize \textcolor{white}{\mbzuai@footmid}}%
            \hfill
            {\footnotesize \textcolor{white}{\mbzuai@footright}}%
            \vfil
        }%
    \end{beamercolorbox}%
}

\mode<all>
