% beamerinnerthemeMBZUAI.sty
% MBZUAI Inner Theme: Title page, blocks, TOC
% Based on MBZUAI Brand Guidelines (March 2026, V1)

\mode<presentation>

% ── Lengths for auto-scaling title ───────────────────────────────────────────
\newlength{\mbzuaiTitleNat}

% ── TOC section style (diamond marker) ─────────────────────────────────────
\setbeamertemplate{section in toc}{%
    \leavevmode
    \tikz[baseline]{\fill[mbzuai-navy] (0,0.15) -- ++(2mm,2mm) -- ++(2mm,-2mm) -- ++(-2mm,-2mm) -- cycle;}
    \hspace{4mm}{\inserttocsection}\par\vspace{2mm}
}

% ── Title Page ──────────────────────────────────────────────────────────────
\setbeamertemplate{title page}{%
    \begin{tikzpicture}[remember picture, overlay]
        % Pattern background — low opacity, behind content
        \node[anchor=center, inner sep=0, opacity=0.06]
            at (current page.center)
            {\includegraphics[width=\paperwidth]{pattern-bg.pdf}};

        % Top navy bar
        \fill[mbzuai-dark-navy]
            (current page.north west) rectangle +(\paperwidth, -28mm);

        % Title (auto-scale: max \Large, shrink if too long)
        \node[anchor=north west, mbzuai-white]
            at ([yshift=-8mm, xshift=15mm]current page.north west)
            {\settowidth{\mbzuaiTitleNat}{\Huge\bfseries\inserttitle}%
             \ifdim\mbzuaiTitleNat>\dimexpr\paperwidth-30mm\relax
                 \resizebox{\dimexpr\paperwidth-30mm\relax}{!}{\textcolor{mbzuai-white}{\bfseries\inserttitle}}%
             \else
                 \textcolor{mbzuai-white}{\Huge\bfseries\inserttitle}%
             \fi};

        % Subtitle
        \node[anchor=north west, mbzuai-sand, font=\large]
            at ([yshift=-18mm, xshift=15mm]current page.north west)
            {\insertsubtitle};
    \end{tikzpicture}

    \vspace{30mm}
    \begin{center}
        {\normalsize \textcolor{mbzuai-text}{\insertauthor}}\\[4mm]
        {\small \textcolor{mbzuai-subtle}{\insertinstitute}}\\[4mm]
        {\small \textcolor{mbzuai-subtle}{\insertdate}}
    \end{center}
}

% ── Thank You Slide ────────────────────────────────────────────────────────
% Usage: \begin{frame} \mbzuaiThankYou \end{frame}
\newcommand{\mbzuaiThankYou}{%
    \begin{tikzpicture}[remember picture, overlay]
        % Pattern background — low opacity
        \node[anchor=center, inner sep=0, opacity=0.06]
            at (current page.center)
            {\includegraphics[width=\paperwidth]{pattern-bg.pdf}};

        % Top navy bar
        \fill[mbzuai-dark-navy]
            (current page.north west) rectangle +(\paperwidth, -12mm);
    \end{tikzpicture}

    \vspace{12mm}
    \begin{center}
        {\Huge \textcolor{mbzuai-dark-navy}{\textbf{Thank You}}}\\[6mm]
        {\Large \textcolor{mbzuai-navy}{Questions?}}\\[8mm]
        {\normalsize
        \textcolor{mbzuai-subtle}{\insertauthor}\\[2mm]
        \textcolor{mbzuai-subtle}{\insertinstitute}
        }
    \end{center}
}

\mode<all>
