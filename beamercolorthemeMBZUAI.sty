% beamercolorthemeMBZUAI.sty
% MBZUAI Brand Color Theme for Beamer
% Based on MBZUAI Brand Guidelines (March 2026, V1)

\mode<presentation>

% ── Brand Colors ────────────────────────────────────────────────────────────
\definecolor{mbzuai-dark-navy}{HTML}{0C2945}
\definecolor{mbzuai-navy}{HTML}{154677}
\definecolor{mbzuai-sand}{HTML}{E5C687}
\definecolor{mbzuai-dark-sand}{HTML}{8A764D}
\definecolor{mbzuai-white}{HTML}{FFFFFF}
\definecolor{mbzuai-light-gray}{HTML}{F5F5F5}
\definecolor{mbzuai-text}{HTML}{1A1A1A}
\definecolor{mbzuai-subtle}{HTML}{666666}

% ── Beamer Color Mappings ──────────────────────────────────────────────────
% Structure
\setbeamercolor{background canvas}{bg=mbzuai-white}
\setbeamercolor{normal text}{fg=mbzuai-text}
\setbeamercolor{structure}{fg=mbzuai-dark-navy}

% Title page
\setbeamercolor{title}{fg=mbzuai-dark-navy}
\setbeamercolor{subtitle}{fg=mbzuai-navy}
\setbeamercolor{author}{fg=mbzuai-subtle}
\setbeamercolor{date}{fg=mbzuai-subtle}
\setbeamercolor{institute}{fg=mbzuai-subtle}

% Frametitle
\setbeamercolor{frametitle}{fg=mbzuai-white, bg=mbzuai-dark-navy}

% Navigation
\setbeamercolor{item}{fg=mbzuai-navy}
\setbeamercolor{subitem}{fg=mbzuai-navy}
\setbeamercolor{subsubitem}{fg=mbzuai-navy}

% Blocks
\setbeamercolor{block title}{fg=mbzuai-white, bg=mbzuai-navy}
\setbeamercolor{block body}{fg=mbzuai-text, bg=mbzuai-light-gray}
\setbeamercolor{block title alerted}{fg=mbzuai-white, bg=mbzuai-dark-sand}
\setbeamercolor{block body alerted}{fg=mbzuai-text, bg=mbzuai-light-gray}
\setbeamercolor{block title example}{fg=mbzuai-white, bg=mbzuai-dark-navy}
\setbeamercolor{block body example}{fg=mbzuai-text, bg=mbzuai-light-gray}

% Table of contents
\setbeamercolor{section in toc}{fg=mbzuai-dark-navy}
\setbeamercolor{subsection in toc}{fg=mbzuai-navy}

% Footer
\setbeamercolor{page number in head/foot}{fg=mbzuai-subtle}

\mode<all>
